{
  "ConnectionStrings": {
    "PostgresDefaultConnection": "Host=localhost;Port=5432;Database=central_organization_db;Username=central_organization_user;Password=Password@123;TrustServerCertificate=True"
  },
  "GrpcServices": {
    "FileServiceUrl": "http://localhost:5082"
  },
  "Jwt": {
    "Authority": "https://localhost:5051",
    "RequireHttpsMetadata": true,
    "ValidateIssuer": true,
    "ValidIssuer": "https://localhost:5051",
    "ValidateAudience": true,
    "Audience": "central-organization-api",
    "ValidateLifetime": true,
    "ClockSkewSeconds": 60,
    "MapInboundClaims": false,
    "NameClaimType": "username",
    "RoleClaimType": "role",
    "IncludeErrorDetails": true,
    "SaveToken": false,
    "BackchannelIgnoreCertificateErrors": false
  },
  "Observability": {
    "ApplicationName": "UMS",
    "Loki": {
      "Enabled": true,
      "Uri": "http://localhost:3100",
      "MinimumLevel": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "Messaging": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "AllowedHosts": "*"
}
