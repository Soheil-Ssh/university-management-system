@page "/auth/change-password"
@model Identity.Api.Pages.Auth.ChangePasswordModel

@{
    ViewData["Title"] = "تغییر رمز عبور";
}

<section class="auth-card">
    <div class="auth-brand">
        <div class="auth-logo">UMS</div>
        <div>
            <h1 class="auth-title">تغییر رمز عبور</h1>
            <p class="auth-subtitle">
                برای ادامه ورود، باید رمز عبور جدیدی برای حساب خود تنظیم کنید.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="validation-summary">
            @Model.ErrorMessage
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <input asp-for="Input.ReturnUrl" type="hidden" />

        <div class="form-group">
            <label asp-for="Input.NewPassword" class="form-label"></label>
            <input asp-for="Input.NewPassword"
                   class="form-input"
                   autocomplete="new-password" />
            <span asp-validation-for="Input.NewPassword"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
            <input asp-for="Input.ConfirmPassword"
                   class="form-input"
                   autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword"></span>
        </div>

        <div class="auth-actions">
            <button type="submit" class="auth-button">
                ثبت رمز جدید و ادامه
            </button>
        </div>
    </form>
</section>