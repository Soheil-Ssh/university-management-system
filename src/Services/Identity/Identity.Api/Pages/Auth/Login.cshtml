@page "/auth/login"
@model Identity.Api.Pages.Auth.LoginModel

@{
    ViewData["Title"] = "ورود";
}

<section class="auth-card">
    <div class="auth-brand">
        <div class="auth-logo">UMS</div>
        <div>
            <h1 class="auth-title">احراز هویت یکپارچه</h1>
            <p class="auth-subtitle">
                برای ادامه، نام کاربری و رمز عبور خود را وارد کنید.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="validation-summary">
            @Model.ErrorMessage
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <input asp-for="Input.ReturnUrl" type="hidden" />

        <div class="form-group">
            <label asp-for="Input.UserName" class="form-label"></label>
            <input asp-for="Input.UserName"
                   class="form-input"
                   autocomplete="username"
                   autofocus />
            <span asp-validation-for="Input.UserName"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Password" class="form-label"></label>
            <input asp-for="Input.Password"
                   class="form-input"
                   autocomplete="current-password" />
            <span asp-validation-for="Input.Password"></span>
        </div>

        <div class="auth-actions">
            <button type="submit" class="auth-button">
                ورود
            </button>
        </div>
    </form>

    <div class="auth-footer">
    </div>
</section>