{
  "ConnectionStrings": {
    "SqlServerDefaultConnection": "Server=Identity_Db;Database=Identity_Db;User=sa;Password=Password123;TrustServerCertificate=True;"
  },
  "SuperAdmin": {
    "UserName": "admin",
    "Email": "admin@university.local",
    "Password": "ChangeMe123!"
  },
  "Jwt": {
    "Authority": "https://localhost:5051",
    "RequireHttpsMetadata": true,
    "ValidateIssuer": true,
    "ValidIssuer": "https://localhost:5051",
    "ValidateAudience": true,
    "Audience": "identity-api",
    "ValidateLifetime": true,
    "ClockSkewSeconds": 60,
    "MapInboundClaims": false,
    "NameClaimType": "username",
    "RoleClaimType": "role",
    "IncludeErrorDetails": true,
    "SaveToken": false
  },
  "IdentityServer": {
    "Signing": {
      "PfxPath": "/certs/identity-signing.pfx",
      "PfxPassword": "change-this-passwordchange-this-password"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1"
      },
      "Https": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8082",
        "Protocols": "Http2"
      }
    }
  },
  "Observability": {
    "ApplicationName": "UMS",
    "Loki": {
      "Enabled": true,
      "Uri": "http://localhost:3100",
      "MinimumLevel": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
