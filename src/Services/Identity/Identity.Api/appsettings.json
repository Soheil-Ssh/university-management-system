{
  "ConnectionStrings": {
    "SqlServerDefaultConnection": "Server=Identity_Db;Database=Identity_Db;User=sa;Password=Password123;TrustServerCertificate=True;"
  },
  "SuperAdmin": {
    "UserName": "admin",
    "FirstName": "Super",
    "LastName": "Admin",
    "Mobile": "09120000000",
    "Email": "admin@university.local",
    "Password": "ChangeMe123!"
  },
  "Jwt": {
    "Authority": "https://localhost:5051",
    "RequireHttpsMetadata": true,
    "ValidateIssuer": true,
    "ValidIssuer": "https://localhost:5051",
    "ValidateAudience": true,
    "Audience": "identity-api",
    "ValidateLifetime": true,
    "ClockSkewSeconds": 60,
    "MapInboundClaims": false,
    "NameClaimType": "username",
    "RoleClaimType": "role",
    "IncludeErrorDetails": true,
    "SaveToken": false
  },
  "IdentityServer": {
    "Signing": {
      "PfxPath": "/certs/identity-signing.pfx",
      "PfxPassword": "change-this-passwordchange-this-password"
    }
  },
  "Observability": {
    "ApplicationName": "UMS",
    "Loki": {
      "Enabled": true,
      "Uri": "http://localhost:3100",
      "MinimumLevel": "Debug"
    },
    "Metrics": {
      "Enabled": true,
      "EndpointPath": "/metrics"
    },
    "Tracing": {
      "Enabled": true,
      "Endpoint": "http://tempo:4318/v1/traces",
      "SamplingRatio": 1.0,
      "ExcludedPathPrefixes": [
        "/health",
        "/health-checks-api"
      ]
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "Messaging": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "AllowedHosts": "*"
}
